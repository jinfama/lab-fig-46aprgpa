/* map-view.js — Choropleth map of Latin America */

import State from '../state.js';
import DataLoader from '../data-loader.js';
import { SEQ_COLORS, fmtUnit } from '../utils.js';
import { showTooltip, hideTooltip } from '../components/tooltip.js';

let _svg, _g, _projection, _path, _colorFn;
let _width = 0, _height = 0;
let _features = [];
let _ro, _zoom;
let _lastGeoLevel = 'country';  // track to detect subnational transitions

export function initMapView() {
    _svg = d3.select('#map-svg');
    _g = _svg.append('g');

    // Enable zoom & pan
    _zoom = d3.zoom()
        .scaleExtent([0.5, 8])
        .on('zoom', (e) => _g.attr('transform', e.transform));
    _svg.call(_zoom);

    const container = document.getElementById('map-container');
    _ro = new ResizeObserver(() => {
        _resize();
        updateMapView();
    });
    _ro.observe(container);
}

function _resize() {
    const container = document.getElementById('map-container');
    if (!container) return;
    _width = container.clientWidth;
    _height = container.clientHeight;
    if (!_svg) return;

    _svg.attr('viewBox', `0 0 ${_width} ${_height}`);

    // Use fitExtent to auto-fit all of Latin America in the viewport
    const geo = DataLoader.getGeo();
    if (geo) {
        const pad = 20;
        _projection = d3.geoMercator()
            .fitExtent([[pad, pad], [_width - pad, _height - pad]], geo);
    } else {
        // Fallback before geo is loaded
        _projection = d3.geoMercator()
            .center([-72, -12])
            .scale(Math.min(_width, _height) * 0.42)
            .translate([_width / 2, _height / 2]);
    }

    _path = d3.geoPath(_projection);
}

export function updateMapView() {
    if (!_svg || !_width) {
        _resize();
        if (!_width) {
            console.log('[MAP] No width yet, skipping render. svg:', !!_svg);
            return;
        }
    }

    const geoLevel = State.get('geoLevel');
    console.log('[MAP] updateMapView called, geoLevel:', geoLevel, 'width:', _width, 'height:', _height);

    if (geoLevel === 'subnational') {
        _renderSubnational();
    } else {
        _renderCountryLevel();
    }
}

function _renderCountryLevel() {
    const geo = DataLoader.getGeo();
    if (!geo) { console.warn('[MAP] No GeoJSON available'); return; }
    console.log('[MAP] Rendering country level, features:', geo.features?.length);

    // If switching back from subnational, clear admin1 elements and reset projection
    if (_lastGeoLevel === 'subnational') {
        _g.selectAll('.admin1-path').remove();
        _g.selectAll('.admin1-border-mesh').remove();
        _g.selectAll('.admin1-outline-mesh').remove();
        _svg.call(_zoom.transform, d3.zoomIdentity); // reset zoom
        _resize(); // reset projection to fit all LATAM
    }
    _lastGeoLevel = 'country';

    _features = geo.features;
    const year = State.get('currentYear');
    const indicator = _getDataField();
    const selected = State.get('selectedCountries');
    const scaleType = State.get('scaleType');

    // Rebuild projection if needed (first time geo is available)
    if (!_path || !_projection) _resize();

    // Get values for color scale (always 'country' since map features are country polygons)
    const values = [];
    _features.forEach(f => {
        const iso3 = f.properties.iso3;
        const val = DataLoader.getValue(iso3, year, indicator, 'country');
        f.properties._value = val;
        if (val != null && val > 0) values.push(val);
    });

    _colorFn = _buildColorScale(values, scaleType);

    // --- Draw country fills (no per-path stroke — borders come from mesh) ---
    const paths = _g.selectAll('.country-path')
        .data(_features, d => d.properties.iso3);

    paths.enter()
        .append('path')
        .attr('class', 'country-path')
        .merge(paths)
        .attr('d', _path)
        .attr('fill', d => {
            const val = d.properties._value;
            return (val != null && val > 0) ? _colorFn(val) : '#E8E0D4';
        })
        .attr('stroke', d => {
            const val = d.properties._value;
            return (val != null && val > 0) ? _colorFn(val) : '#E8E0D4';
        })
        .attr('stroke-width', 0.5)
        .classed('selected', d => selected.includes(d.properties.iso3))
        .on('click', (event, d) => {
            State.toggleCountry(d.properties.iso3);
        })
        .on('mouseenter', (event, d) => {
            const val = d.properties._value;
            const unit = _getUnit();
            showTooltip(event, {
                title: d.properties.name,
                value: fmtUnit(val, unit),
                sub: `${year}`,
            });
        })
        .on('mousemove', (event) => {
            showTooltip(event);
        })
        .on('mouseleave', () => {
            hideTooltip();
        });

    paths.exit().remove();

    // --- Shared borders via topojson.mesh() — clean lines, no gaps ---
    const topo = DataLoader.getTopo();
    if (topo) {
        const borders = topojson.mesh(topo, topo.objects.countries,
            (a, b) => a !== b);

        _g.selectAll('.border-mesh').remove();
        _g.append('path')
            .datum(borders)
            .attr('class', 'border-mesh')
            .attr('d', _path)
            .attr('fill', 'none')
            .attr('stroke', 'rgba(139,94,60,0.25)')
            .attr('stroke-width', 0.5)
            .attr('stroke-linejoin', 'round')
            .attr('pointer-events', 'none');

        const outline = topojson.mesh(topo, topo.objects.countries,
            (a, b) => a === b);
        _g.selectAll('.outline-mesh').remove();
        _g.append('path')
            .datum(outline)
            .attr('class', 'outline-mesh')
            .attr('d', _path)
            .attr('fill', 'none')
            .attr('stroke', 'rgba(139,94,60,0.15)')
            .attr('stroke-width', 0.3)
            .attr('stroke-linejoin', 'round')
            .attr('pointer-events', 'none');
    }

    // --- Selection highlights (drawn on top) ---
    const selData = _features.filter(f => selected.includes(f.properties.iso3));
    const selPaths = _g.selectAll('.country-selection')
        .data(selData, d => d.properties.iso3);

    selPaths.enter()
        .append('path')
        .attr('class', 'country-selection')
        .merge(selPaths)
        .attr('d', _path)
        .attr('fill', 'none')
        .attr('stroke', 'var(--c-accent)')
        .attr('stroke-width', 2)
        .attr('pointer-events', 'none');

    selPaths.exit().remove();

    document.getElementById('map-year').textContent = State.get('currentYear');
    _updateLegend(values);
}

function _renderSubnational() {
    if (!DataLoader.isSubnationalLoaded()) return;

    _lastGeoLevel = 'subnational';

    // Clear country-level elements and reset zoom
    _svg.call(_zoom.transform, d3.zoomIdentity);
    _g.selectAll('.country-path').remove();
    _g.selectAll('.border-mesh').remove();
    _g.selectAll('.outline-mesh').remove();
    _g.selectAll('.country-selection').remove();

    const year = State.get('currentYear');
    const indicator = _getDataField();
    const selected = State.get('selectedCountries');
    const scaleType = State.get('scaleType');
    const unit = _getUnit();

    // Determine which country to show (first selected, or all subnational countries)
    const subCountries = DataLoader.getSubnationalCountries();
    const activeIso = selected.length > 0 && subCountries.includes(selected[0])
        ? selected[0] : null;

    // Get admin1 geo features
    const subGeo = DataLoader.getSubnationalGeo(activeIso);
    if (!subGeo || subGeo.features.length === 0) {
        _g.selectAll('.admin1-path').remove();
        _g.selectAll('.admin1-border-mesh').remove();
        _g.selectAll('.admin1-outline-mesh').remove();
        document.getElementById('map-year').textContent = year;
        return;
    }

    // Fit projection to the subnational features
    const pad = 20;
    _projection = d3.geoMercator()
        .fitExtent([[pad, pad], [_width - pad, _height - pad]], subGeo);
    _path = d3.geoPath(_projection);

    // Compute values
    const values = [];
    subGeo.features.forEach(f => {
        const iso3 = f.properties.iso3;
        const adminName = f.properties.admin_name;
        const val = DataLoader.getSubnationalValue(iso3, adminName, year, indicator);
        f.properties._value = val;
        if (val != null && val > 0) values.push(val);
    });

    _colorFn = _buildColorScale(values, scaleType);

    // Draw admin1 fills
    const paths = _g.selectAll('.admin1-path')
        .data(subGeo.features, d => `${d.properties.iso3}::${d.properties.admin_name}`);

    paths.enter()
        .append('path')
        .attr('class', 'admin1-path')
        .merge(paths)
        .attr('d', _path)
        .attr('fill', d => {
            const val = d.properties._value;
            return (val != null && val > 0) ? _colorFn(val) : '#E8E0D4';
        })
        .attr('stroke', d => {
            const val = d.properties._value;
            return (val != null && val > 0) ? _colorFn(val) : '#E8E0D4';
        })
        .attr('stroke-width', 0.5)
        .style('cursor', 'pointer')
        .on('click', (event, d) => {
            // Select the parent country
            const iso3 = d.properties.iso3;
            if (!selected.includes(iso3)) {
                State.addCountry(iso3);
            }
        })
        .on('mouseenter', (event, d) => {
            const val = d.properties._value;
            const countryName = DataLoader.getCountryName(d.properties.iso3);
            showTooltip(event, {
                title: d.properties.admin_name,
                value: fmtUnit(val, unit),
                sub: `${countryName} — ${year}`,
            });
        })
        .on('mousemove', (event) => showTooltip(event))
        .on('mouseleave', () => hideTooltip());

    paths.exit().remove();

    // Admin1 borders using topojson.mesh
    const subTopo = DataLoader.getSubnationalTopo();
    if (subTopo) {
        _g.selectAll('.admin1-border-mesh').remove();

        // If showing a single country, filter the mesh
        const borders = topojson.mesh(subTopo, subTopo.objects.admin1,
            (a, b) => a !== b);
        _g.append('path')
            .datum(borders)
            .attr('class', 'admin1-border-mesh')
            .attr('d', _path)
            .attr('fill', 'none')
            .attr('stroke', 'rgba(139,94,60,0.3)')
            .attr('stroke-width', 0.5)
            .attr('stroke-linejoin', 'round')
            .attr('pointer-events', 'none');

        _g.selectAll('.admin1-outline-mesh').remove();
        const outline = topojson.mesh(subTopo, subTopo.objects.admin1,
            (a, b) => a === b);
        _g.append('path')
            .datum(outline)
            .attr('class', 'admin1-outline-mesh')
            .attr('d', _path)
            .attr('fill', 'none')
            .attr('stroke', 'rgba(139,94,60,0.5)')
            .attr('stroke-width', 1)
            .attr('stroke-linejoin', 'round')
            .attr('pointer-events', 'none');
    }

    document.getElementById('map-year').textContent = year;
    _updateLegend(values);
}

function _buildColorScale(values, scaleType) {
    if (values.length === 0) return () => SEQ_COLORS[0];
    if (scaleType === 'log') {
        const safeMin = Math.max(1, d3.min(values));
        return d3.scaleLog()
            .domain([safeMin, d3.max(values)])
            .range([SEQ_COLORS[1], SEQ_COLORS[SEQ_COLORS.length - 1]])
            .interpolate(d3.interpolateRgb)
            .clamp(true);
    }
    return d3.scaleQuantile()
        .domain(values.sort((a, b) => a - b))
        .range(SEQ_COLORS.slice(1));
}

function _updateLegend(values) {
    const legend = document.getElementById('map-legend');
    if (!legend || values.length === 0) {
        if (legend) legend.innerHTML = '';
        return;
    }

    const indicator = _getActiveIndicatorLabel();
    const unit = _getUnit();
    const sorted = values.slice().sort((a, b) => a - b);
    const min = sorted[0];
    const max = sorted[sorted.length - 1];

    // Use the actual range colors (skipping lightest)
    const legendColors = SEQ_COLORS.slice(1);

    legend.innerHTML = `
        <div class="map-legend-title">${indicator}</div>
        <div class="map-legend-bar">
            ${legendColors.map(c => `<div class="map-legend-cell" style="background:${c}"></div>`).join('')}
        </div>
        <div class="map-legend-labels">
            <span>${fmtUnit(min, unit)}</span>
            <span>${fmtUnit(max, unit)}</span>
        </div>
    `;
}

function _getDataField() {
    const meta = DataLoader.getMetadata();
    const cat = meta.categories.find(c => c.id === State.get('activeCategory'));
    if (!cat) return 'production';
    for (const group of (cat.indicatorGroups || [])) {
        for (const ind of group.indicators) {
            if (ind.id === State.get('activeIndicator')) return ind.dataField;
        }
    }
    return 'production';
}

function _getUnit() {
    const mode = State.get('axisMode');
    if (mode === 'index') return 'index100';
    if (mode === 'pct_total') return '%';

    const meta = DataLoader.getMetadata();
    const cat = meta.categories.find(c => c.id === State.get('activeCategory'));
    if (!cat) return 'toneladas';
    for (const group of (cat.indicatorGroups || [])) {
        for (const ind of group.indicators) {
            if (ind.id === State.get('activeIndicator')) return ind.unit;
        }
    }
    return 'toneladas';
}

function _getActiveIndicatorLabel() {
    const meta = DataLoader.getMetadata();
    const cat = meta.categories.find(c => c.id === State.get('activeCategory'));
    if (!cat) return '';
    for (const group of (cat.indicatorGroups || [])) {
        for (const ind of group.indicators) {
            if (ind.id === State.get('activeIndicator')) return ind.label;
        }
    }
    return '';
}
